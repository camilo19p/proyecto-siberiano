# Dockerfile para Frontend - Siberiano (Desarrollo)
FROM node:20-alpine

WORKDIR /app

# Copiar package files
COPY package*.json ./

# Instalar dependencias
RUN npm ci

# Copiar código fuente
COPY . .

# Exponer puerto
EXPOSE 5173

# Variables de entorno
ENV NODE_ENV=development

# Dev server de Vite
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
