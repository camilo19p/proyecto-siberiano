@echo off
REM VERIFICACION COMPLETA DEL MODULO

echo.
echo ????????????????????????????????????????????????????????????
echo  VERIFICACION COMPLETA DEL MODULO CLIENTES
echo ????????????????????????????????????????????????????????????
echo.

setlocal enabledelayedexpansion

REM 1. Verificar que Clientes.tsx existe
echo [1/8] żExiste Clientes.tsx?
if exist "web\src\components\Clientes.tsx" (
    echo ? SI - Archivo encontrado
    for /f "usebackq" %%A in ('dir /b "web\src\components\Clientes.tsx"') do echo   Tamańo: %%~zA bytes
) else (
    echo ? NO - PROBLEMA CRITICO
    goto error
)
echo.

REM 2. Verificar que Clientes está importado en App.tsx
echo [2/8] żEstá importado Clientes en App.tsx?
findstr /C:"import { Clientes }" "web\src\App.tsx" >nul
if %errorlevel% equ 0 (
    echo ? SI - Import encontrado
) else (
    echo ? NO - PROBLEMA
    goto error
)
echo.

REM 3. Verificar que está en el menú
echo [3/8] żEstá Clientes en el menú?
findstr /C:"'clientes' as Page" "web\src\App.tsx" >nul
if %errorlevel% equ 0 (
    echo ? SI - Menú configurado
) else (
    echo ? NO - PROBLEMA
    goto error
)
echo.

REM 4. Verificar renderización
echo [4/8] żEstá renderizado el componente?
findstr /C:"page === 'clientes' && <Clientes" "web\src\App.tsx" >nul
if %errorlevel% equ 0 (
    echo ? SI - Renderización OK
) else (
    echo ? NO - PROBLEMA
    goto error
)
echo.

REM 5. Verificar puerto 4173
echo [5/8] żPuerto 4173 configurado en vite.config.ts?
findstr /C:"port: 4173" "web\vite.config.ts" >nul
if %errorlevel% equ 0 (
    echo ? SI - Puerto correcto
) else (
    echo ? NO - PROBLEMA
    goto error
)
echo.

REM 6. Verificar .env.local
echo [6/8] żExiste .env.local?
if exist "web\.env.local" (
    echo ? SI - Archivo encontrado
    findstr "VITE_API_URL" "web\.env.local" >nul
    if %errorlevel% equ 0 (
        echo ? SI - Variable API_URL configurada
    ) else (
        echo ??  WARNING - VITE_API_URL no configurada
    )
) else (
    echo ??  WARNING - .env.local no existe
)
echo.

REM 7. Verificar que vite.config.ts tiene proxy correcto
echo [7/8] żProxy hacia API configurado?
findstr /C:"'/api'" "web\vite.config.ts" >nul
if %errorlevel% equ 0 (
    echo ? SI - Proxy OK
) else (
    echo ? NO - PROBLEMA
    goto error
)
echo.

REM 8. Verificar que clienteRoutes existe en backend
echo [8/8] żclienteRoutes.ts existe en backend?
if exist "api\src\routes\clienteRoutes.ts" (
    echo ? SI - Backend OK
) else (
    echo ??  WARNING - Rutas de clientes no encontradas
)
echo.

echo ????????????????????????????????????????????????????????????
echo  ? TODO ESTA CORRECTO
echo ????????????????????????????????????????????????????????????
echo.
echo El problema es SOLAMENTE caché del navegador.
echo.
echo SOLUCION:
echo   1. Abre DevTools (F12)
echo   2. Application ? Cookies ? Elimina http://localhost:4173
echo   3. Cierra navegador completamente
echo   4. Abre http://localhost:4173
echo   5. Presiona Ctrl+F5
echo.
pause
exit /b 0

:error
echo.
echo ????????????????????????????????????????????????????????????
echo  ? HAY UN PROBLEMA
echo ????????????????????????????????????????????????????????????
echo.
echo Ejecuta: SOLUCION_FINAL.bat
echo.
pause
exit /b 1
