@echo off
REM SOLUCION FINAL - Fuerza rebuild y limpiza caché

color 0A
cls

echo.
echo ???????????????????????????????????????????????????????????????
echo   SOLUCION FINAL - MODULO CLIENTES (FORCE REBUILD)
echo ???????????????????????????????????????????????????????????????
echo.

cd /d "%~dp0"

REM Paso 1: Matar todos los procesos Node
echo [1/6] Cerrando procesos anteriores...
taskkill /F /IM node.exe >nul 2>&1
taskkill /F /IM npm.cmd >nul 2>&1
timeout /t 2 >nul
echo ? Procesos cerrados
echo.

REM Paso 2: Limpiar compilación anterior
echo [2/6] Limpiando build anterior...
cd /d "%~dp0web"
if exist "dist" rmdir /s /q "dist" >nul 2>&1
if exist ".vite" rmdir /s /q ".vite" >nul 2>&1
echo ? Build limpiado
echo.

REM Paso 3: Limpiar caché de vite
echo [3/6] Limpiando caché de Vite...
if exist "node_modules\.vite" rmdir /s /q "node_modules\.vite" >nul 2>&1
echo ? Caché limpiado
echo.

REM Paso 4: Verificar que Clientes.tsx existe
echo [4/6] Verificando archivos...
if exist "%~dp0web\src\components\Clientes.tsx" (
    echo ? Clientes.tsx existe
) else (
    echo ? ERROR: Clientes.tsx NO existe
    pause
    exit /b 1
)

if exist "%~dp0web\src\App.tsx" (
    echo ? App.tsx existe
) else (
    echo ? ERROR: App.tsx NO existe
    pause
    exit /b 1
)
echo.

REM Paso 5: Iniciar Backend
echo [5/6] Iniciando Backend en puerto 3001...
cd /d "%~dp0api"
start "Backend - Siberiano API" cmd /k "npm run dev"
timeout /t 3 >nul
echo ? Backend iniciado
echo.

REM Paso 6: Iniciar Frontend (con force rebuild)
echo [6/6] Iniciando Frontend en puerto 4173...
cd /d "%~dp0web"
start "Frontend - Siberiano" cmd /k "npm run dev -- --port 4173 --force"

echo.
echo ???????????????????????????????????????????????????????????????
echo   ? LISTO - ABRIENDO NAVEGADOR
echo ???????????????????????????????????????????????????????????????
echo.

timeout /t 5 >nul
start http://localhost:4173/

echo.
echo ?? FRONTEND: http://localhost:4173/
echo ?? BACKEND:  http://localhost:3001/
echo.
echo ??  SI SIGUE SIN VERSE:
echo    1. Abre DevTools (F12)
echo    2. Ve a Application ? Cookies ? http://localhost:4173
echo    3. Elimina TODOS los cookies
echo    4. Cierra pestańa
echo    5. Abre nuevamente http://localhost:4173/
echo    6. Presiona Ctrl+F5 (hard refresh)
echo.
echo El módulo debe estar en el menú entre "Inventario" y "Ganancias"
echo.
pause
