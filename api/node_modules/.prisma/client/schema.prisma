generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("VENDEDOR")
  estado    String   @default("ACTIVO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
}

model Product {
  id              Int              @id @default(autoincrement())
  codigo          String           @unique
  name            String
  type            String           @default("GENERAL")
  categoria       String           @default("GENERAL")
  precioCompra    Float
  precioVenta     Float
  stock           Int              @default(0)
  stockMinimo     Int              @default(5)
  stockInicial    Int              @default(0)
  imagen          String?
  descripcion     String?
  estado          String           @default("ACTIVO")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  saleItems       SaleItem[]
  inventario      Inventario[]
  inventarioItems InventarioItem[]

  @@index([codigo])
}

model Client {
  id            Int      @id @default(autoincrement())
  nombres       String
  apellidos     String?
  documento     String   @unique
  tipoDocumento String   @default("CC")
  telefono      String?
  email         String?
  ciudad        String?
  direccion     String?
  barrio        String?
  cupo          Float    @default(0)
  saldo         Float    @default(0)
  estado        String   @default("ACTIVO")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sales         Sale[]
}

model Sale {
  id            Int        @id @default(autoincrement())
  numero        String     @unique
  fecha         DateTime   @default(now())
  subtotal      Float
  iva           Float
  total         Float
  metodoPago    String     @default("cash")
  estado        String     @default("COMPLETADA")
  clienteId     Int?
  userId        Int
  observaciones String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  client        Client?    @relation(fields: [clienteId], references: [id])
  user          User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items         SaleItem[]

  dianPrefijo     String?
  dianConsecutivo String?
  dianFecha       DateTime?
  dianCufe        String?
  dianQr          String?

  @@index([fecha])
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  saleId     Int
  productId  Int
  cantidad   Int
  precioUnit Float
  subtotal   Float
  sale       Sale    @relation(fields: [saleId], references: [id])
  product    Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Inventario {
  id         Int      @id @default(autoincrement())
  fecha      DateTime @default(now())
  productoId Int
  tipo       String
  cantidad   Int
  motivo     String?
  usuarioId  Int
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productoId], references: [id])

  totalVendido  Float            @default(0)
  ganancias     Float            @default(0)
  prestamo      Float            @default(0)
  deudaRestante Float            @default(0)
  capital       Float            @default(0)
  observaciones String?
  items         InventarioItem[]
}

model InventarioItem {
  id           Int        @id @default(autoincrement())
  inventarioId Int
  productId    Int
  inventario   Inventario @relation(fields: [inventarioId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
  entraron     Int        @default(0)
  quedaron     Int        @default(0)
  salieron     Int        @default(0)
  totalVendido Float      @default(0)
  ganancia     Float      @default(0)
  createdAt    DateTime   @default(now())
}

model Nota {
  id        Int      @id @default(autoincrement())
  fecha     String
  titulo    String
  contenido String
  color     String?
  userId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Configuracion {
  id          Int     @id @default(autoincrement())
  clave       String  @unique
  valor       String
  descripcion String?
}

model Caja {
  id             Int            @id @default(autoincrement())
  fecha          DateTime       @default(now())
  entradaInicial Float          @default(0)
  totalVentas    Float          @default(0)
  totalEfectivo  Float          @default(0)
  totalTarjeta   Float          @default(0)
  totalTransfer  Float          @default(0)
  salidaCaja     Float          @default(0)
  cierreReal     Float          @default(0)
  diferencia     Float          @default(0)
  observaciones  String?
  estado         String         @default("ABIERTA")
  userId         Int
  createdAt      DateTime       @default(now())
  movements      CashMovement[]
}

model CashMovement {
  id        Int      @id @default(autoincrement())
  cajaId    Int
  tipo      String // "INGRESO" o "EGRESO"
  monto     Float
  concepto  String
  hora      DateTime @default(now())
  caja      Caja     @relation(fields: [cajaId], references: [id])
  createdAt DateTime @default(now())
}

model Payable {
  id               Int              @id @default(autoincrement())
  proveedor        String
  concepto         String
  monto            Float
  montoPagado      Float            @default(0)
  estado           String           @default("PENDIENTE")
  fechaPendiente   DateTime
  fechaVencimiento DateTime?
  notificado       Boolean          @default(false)
  observaciones    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  payments         PaymentHistory[]
}

model PaymentHistory {
  id        Int      @id @default(autoincrement())
  payableId Int
  monto     Float
  fecha     DateTime @default(now())
  payable   Payable  @relation(fields: [payableId], references: [id])
  createdAt DateTime @default(now())
}

model CajaAudit {
  id             Int      @id @default(autoincrement())
  fecha          DateTime @default(now())
  usuarioId      Int
  ventasEfectivo Float
  base           Float
  gastos         Float
  saldoEsperado  Float
  saldoReal      Float
  diferencia     Float
  observaciones  String?
  createdAt      DateTime @default(now())

  @@index([fecha])
}
