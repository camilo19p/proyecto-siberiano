datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id              Int              @id @default(autoincrement())
  codigo          String           @unique
  name            String
  type            String
  precioCompra    Float
  precioVenta     Float
  stock           Int
  stockInicial    Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  inventarioItems InventarioItem[]

  @@map("products")
}

model Inventario {
  id            Int              @id @default(autoincrement())
  fecha         DateTime         @default(now())
  totalVendido  Float            @default(0)
  ganancias     Float            @default(0)
  prestamo      Float            @default(0)
  deudaRestante Float            @default(0)
  capital       Float            @default(0)
  observaciones String?
  createdAt     DateTime         @default(now())
  items         InventarioItem[]

  @@map("inventarios")
}

model InventarioItem {
  id           Int        @id @default(autoincrement())
  inventarioId Int
  productId    Int
  entraron     Int
  quedaron     Int
  salieron     Int
  totalVendido Float
  ganancia     Float
  inventario   Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  producto     Product    @relation(fields: [productId], references: [id])

  @@map("inventario_items")
}
