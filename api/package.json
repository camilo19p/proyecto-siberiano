{
  "name": "siberiano-api",
  "version": "1.0.0",
  "description": "API Backend para Sistema Siberiano",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node index.ts",
    "start:dev": "npm run prisma:generate && ts-node index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "clean": "rm -rf node_modules .prisma dist",
    "clean:windows": "rmdir /s /q node_modules .prisma dist 2>nul || true",
    "setup": "npm install && npm run prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "prisma": "^5.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
