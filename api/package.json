{
  "name": "siberiano-api",
  "version": "1.0.0",
  "description": "API Backend para Sistema Siberiano",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node index.ts",
    "start:dev": "npm run prisma:generate && ts-node index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "clean": "rm -rf node_modules .prisma dist",
    "clean:windows": "rmdir /s /q node_modules .prisma dist 2>nul || true",
    "setup": "npm install && npm run prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
