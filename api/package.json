{
  "name": "siberiano-api",
  "version": "1.0.0",
  "description": "API Backend para Sistema Siberiano",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node index.ts",
    "start:dev": "npm run prisma:generate && ts-node index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "clean": "rm -rf node_modules .prisma dist",
    "clean:windows": "rmdir /s /q node_modules .prisma dist 2>nul || true",
    "setup": "npm install && npm run prisma:generate"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/morgan": "^1.9.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "prisma": "^5.7.0",
    "react-hot-toast": "^2.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.19",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
